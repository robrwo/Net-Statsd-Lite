#!perl

use utf8;

use v5.14;
use warnings;

[
    {
        description => "set",
        autoflush   => 1,
        prefix      => 'foo.',
        input       => [ [qw/ secure_set_add addresses 192.168.0.1 /], ],
        output      => "foo.addresses:UBcaNnUVKueb75w23fWxbTnhiFU|s\n",
    },
    {
        description => "set (utf8 value)",
        autoflush   => 1,
        prefix      => 'foo.',
        input       => [ [ qw/ secure_set_add places Äland/, ], ],
        output      => "foo.places:plARHWj9eR6Bk7iG5G5fGV1fRc8|s\n",
    },

]
